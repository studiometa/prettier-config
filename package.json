{
  "name": "@studiometa/prettier-config",
  "version": "4.4.0",
  "description": "Prettier configuration",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/*",
    "README.md"
  ],
  "dependencies": {
    "@shopify/prettier-plugin-liquid": "1.10.0",
    "@studiometa/prettier-formatter-gitlab": "^2.1.1",
    "@zackad/prettier-plugin-twig": "^0.16.0",
    "prettier": "^3.6.2"
  },
  "devDependencies": {
    "@studiometa/eslint-config": "4.3.1",
    "esbuild": "0.25.11",
    "typescript": "5.9.3",
    "vitest": "4.0.5"
  },
  "scripts": {
    "pretest": "npm run build:pkg",
    "test": "vitest run",
    "test:watch": "vitest",
    "prelint:scripts": "npm run build:pkg",
    "lint": "npm run lint:scripts && npm run lint:types",
    "lint:scripts": "eslint src/ --cache",
    "lint:types": "tsc --build tsconfig.lint.json",
    "fix": "npm run fix:scripts",
    "fix:scripts": "npm run lint:scripts -- --fix",
    "build": "npm run build:pkg && npm run build:types",
    "build:types": "tsc --build tsconfig.build.json",
    "build:pkg": "esbuild 'src/**/*.ts' --outdir=dist --target=esnext --format=esm --sourcemap"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/studiometa/prettier-config.git"
  },
  "author": "Studio Meta <agence@studiometa.fr> (https://www.studiometa.fr)",
  "contributors": [
    "Titouan Mathis <titouan@studiometa.fr>"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/studiometa/prettier-config/issues"
  },
  "homepage": "https://github.com/studiometa/prettier-config#readme"
}
